{
  "openapi": "3.0.0",
  "info": {
    "title": "Apex Closr Deal Flow API",
    "version": "1.0.0",
    "description": "Real estate deal flow API for Apex Closr"
  },
  "servers": [
    { "url": "https://apex-deal-flow-api.onrender.com" }
  ],
  "paths": {
    "/leads": {
      "get": {
        "operationId": "getLeads",
        "summary": "List all leads",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "sort", "in": "query", "schema": { "type": "string", "default": "-created_date" } }
        ],
        "responses": {
          "200": { "description": "List of leads" }
        }
      }
    },
    "/leads/hot": {
      "get": {
        "operationId": "getHotLeads",
        "summary": "Get hot leads with high deal scores",
        "parameters": [
          { "name": "minScore", "in": "query", "schema": { "type": "integer", "default": 80 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "List of hot leads" }
        }
      }
    },
    "/leads/search": {
      "get": {
        "operationId": "searchLeads",
        "summary": "Search leads by query",
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Search results" }
        }
      }
    },
    "/leads/{id}": {
      "get": {
        "operationId": "getLeadDetail",
        "summary": "Get a single lead by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Lead detail" }
        }
      }
    },
    "/stats/dashboard": {
      "get": {
        "operationId": "getDashboardStats",
        "summary": "Get dashboard statistics",
        "responses": {
          "200": { "description": "Dashboard stats" }
        }
      }
    }
  }
}
